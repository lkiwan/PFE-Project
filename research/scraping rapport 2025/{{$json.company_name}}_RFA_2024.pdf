<article class="row">
  <div class="content portfolio col-sm-12 col-md-12">
                <table>
                  <p>  <div class="layout layout--onecol">
    <div  class="layout__region layout__region--content">
        <tr >
    <td><b>Emetteur</b></td>
       <td>
             <a href="/fr/espace-emetteurs/immorente-invest" hreflang="fr">IMMORENTE INVEST</a><br>
            </td>
        </tr>
  <tr >
    <td><b>Année</b></td>
       <td>
             <time datetime="2025-12-31T11:15:00Z">2025</time>
<br>
            </td>
        </tr>
  <tr >
    <td><b>Rapports financiers</b></td>
       <td>
             Rapports annuels<br>
            </td>
        </tr>
  <tr >
    <td><b>Pièce jointe</b></td>
    <div class="multiple file field_attachement">
             <td>
             <span class="file file--mime-application-pdf file--application-pdf"><a href="/sites/default/files/Immorente_Invest_RFA_2025.pdf" type="application/pdf">Immorente_Invest_RFA_2025.pdf</a></span>
  <span>(9.5 Mo)</span>
<br>
